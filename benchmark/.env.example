# =====================================================
# Benchmark Suite Environment Variables
# Copy to .env and fill in with your local test values
# =====================================================

# === Service URLs ===
USER_BE_URL=http://localhost:3000
COMP_QUEUE_URL=http://localhost:3005
SELF_URL=http://localhost:3030

# === Test User Credentials ===
# A real user in your local Postgres DB.
BENCH_USER_EMAIL=testuser@example.com
BENCH_USER_PASSWORD=yourpassword123

# === Complaint Seed Data ===
# A valid categoryId UUID from your local DB.
# Run: SELECT id FROM "Category" LIMIT 1;
BENCH_CATEGORY_ID=00000000-0000-0000-0000-000000000000
BENCH_SUB_CATEGORY=Pothole

# === Benchmark Tuning ===
# Concurrent connections for ingestion bench (default 200)
INGESTION_CONNECTIONS=200
# Duration in seconds for ingestion test (default 30)
INGESTION_DURATION=30
# Number of complaints to seed into queue (default 1000)
SEED_COUNT=1000
